{
    "name": "code-everywhere",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "A structured Apple-first control surface for Every Code sessions.",
    "packageManager": "pnpm@10.10.0",
    "scripts": {
        "cockpit:server": "pnpm --filter @code-everywhere/server start",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:dry-run": "eslint . --fix-dry-run",
        "smoke:cockpit:real-tui": "node scripts/smoke-cockpit-real-tui-live-loop.mjs",
        "smoke:cockpit:real-tui:approval-deny": "CODE_EVERYWHERE_SMOKE_PENDING_WORK=1 CODE_EVERYWHERE_SMOKE_APPROVAL_DECISION=deny node scripts/smoke-cockpit-real-tui-live-loop.mjs",
        "smoke:cockpit:real-tui:pending-work": "CODE_EVERYWHERE_SMOKE_PENDING_WORK=1 node scripts/smoke-cockpit-real-tui-live-loop.mjs",
        "smoke:cockpit:retained-pruned": "node scripts/smoke-cockpit-retained-pruned-browser.mjs",
        "smoke:cockpit:turns": "node scripts/smoke-cockpit-turn-lifecycle.mjs",
        "smoke:cockpit:web": "node scripts/smoke-cockpit-web-live-loop.mjs",
        "typecheck": "pnpm --recursive typecheck",
        "test": "pnpm --recursive test",
        "validate": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
    },
    "devDependencies": {
        "@eslint/js": "latest",
        "@types/node": "latest",
        "eslint": "latest",
        "prettier": "latest",
        "typescript": "6.0.3",
        "typescript-eslint": "latest",
        "vitest": "latest"
    }
}
