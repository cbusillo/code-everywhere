{
    "name": "@code-everywhere/server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "node": {
                "development": "./src/index.ts",
                "default": "./dist/index.js"
            },
            "default": "./src/index.ts"
        },
        "./http": {
            "types": "./src/http.ts",
            "node": {
                "development": "./src/http.ts",
                "default": "./dist/http.js"
            },
            "default": "./src/http.ts"
        },
        "./http-client": {
            "types": "./src/http-client.ts",
            "node": {
                "development": "./src/http-client.ts",
                "default": "./dist/http-client.js"
            },
            "default": "./src/http-client.ts"
        },
        "./trust": {
            "types": "./src/trust.ts",
            "node": {
                "development": "./src/trust.ts",
                "default": "./dist/trust.js"
            },
            "default": "./src/trust.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "pnpm --filter @code-everywhere/contracts build && pnpm build && node dist/cli.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "node ../../scripts/run-vitest-development.mjs run src --passWithNoTests"
    },
    "dependencies": {
        "@code-everywhere/contracts": "workspace:*"
    },
    "devDependencies": {}
}
